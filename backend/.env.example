# Server
PORT=5000
NODE_ENV=development

# MongoDB — Atlas only (no local URI needed)
MONGO_ENV=atlas
MONGO_URI_ATLAS=

# JWT — generate two different long random strings
# Run in terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_STRING_HERE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Phase 3 — fill later)
EMAIL_USER=
EMAIL_PASS=

# Cloudinary (Phase 7 — fill later)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (Phase 5 — fill later)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_SINGLE_PROPERTY=
RAZORPAY_PLAN_FRANCHISE=

# CORS
CORS_ORIGINS=http://localhost:5173